APP_NAME=Serenity
APP_VERSION=0.0.1

RAG_DATASET=mental_health_counseling_conversations_combined_dataset
GROUPED_RAG_DATASET=grouped_mental_health_counseling_conversations_combined_dataset

GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

GEMINI_GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
SIDE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
RERANKING_MODEL=cross-encoder/stsb-roberta-base
INTENT_CLASSIFICATION_MODEL=llama-3.1-8b-instant


TOP_K=3
TOP_R=10

EMBEDDINGS_COLLECTION_NAME=mental_health
DEVICE=cpu

EMBEDDING_SIZE=1024

MAX_MESSAGES=10
TTL_SECONDS=3600

SUMMARIZE_RETRIEVALS=true

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_DECODE_RESPONSE=true

APP_HOST=localhost
APP_PORT=8000

QDRANT_API_KEY=your_qdrant_api_key
QDRANT_CLUSTER_ENDPOINT=your_qdrant_cluster_endpoint