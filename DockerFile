# syntax=docker/dockerfile:1
FROM python:3.12-slim

WORKDIR /app

# Install dependencies with pip.
# A persistent BuildKit cache mount keeps downloaded wheels between builds,
# so re-runs reuse them instead of re-downloading.
COPY Backend/requirements.txt ./
# Install CPU-only torch first (avoids the ~500 MB / multi-GB CUDA build),
# then the remaining requirements.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip \
    && pip install torch --index-url https://download.pytorch.org/whl/cpu \
    && pip install -r requirements.txt

# Copy the Backend FastAPI application
COPY Backend/ ./

# Default host/port (overridable at runtime via env)
ENV APP_HOST=0.0.0.0 \
    APP_PORT=8000

EXPOSE 8000

CMD ["python", "main.py"]
